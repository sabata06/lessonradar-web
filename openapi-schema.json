components:
  schemas:
    Assignment:
      type: object
      description: Serializer for Assignment model.
      properties:
        id:
          type: integer
          readOnly: true
        is_overdue:
          type: string
          readOnly: true
        student_name:
          type: string
          readOnly: true
        student_surname:
          type: string
          readOnly: true
        book:
          type: string
          maxLength: 255
        topic:
          type: string
          maxLength: 255
        page:
          type: string
          maxLength: 50
        description:
          type: string
          nullable: true
        is_completed:
          type: boolean
        due_date:
          type: string
          format: date
          nullable: true
        completion_date:
          type: string
          format: date
          nullable: true
        date_added:
          type: string
          format: date-time
          readOnly: true
        teacher:
          type: integer
          readOnly: true
        student:
          type: integer
        lesson:
          type: integer
          nullable: true
      required:
      - book
      - date_added
      - id
      - is_overdue
      - page
      - student
      - student_name
      - student_surname
      - teacher
      - topic
    AssignmentRequest:
      type: object
      description: Serializer for Assignment model.
      properties:
        book:
          type: string
          minLength: 1
          maxLength: 255
        topic:
          type: string
          minLength: 1
          maxLength: 255
        page:
          type: string
          minLength: 1
          maxLength: 50
        description:
          type: string
          nullable: true
        is_completed:
          type: boolean
        due_date:
          type: string
          format: date
          nullable: true
        completion_date:
          type: string
          format: date
          nullable: true
        student:
          type: integer
        lesson:
          type: integer
          nullable: true
      required:
      - book
      - page
      - student
      - topic
    BlankEnum:
      enum:
      - ''
    DayOfWeekEnum:
      enum:
      - monday
      - tuesday
      - wednesday
      - thursday
      - friday
      - saturday
      - sunday
      type: string
      description: |-
        * `monday` - Pazartesi
        * `tuesday` - Salı
        * `wednesday` - Çarşamba
        * `thursday` - Perşembe
        * `friday` - Cuma
        * `saturday` - Cumartesi
        * `sunday` - Pazar
    Lesson:
      type: object
      description: Serializer for Lesson model.
      properties:
        id:
          type: integer
          readOnly: true
        student_name:
          type: string
          readOnly: true
        student_surname:
          type: string
          readOnly: true
        parent_contact:
          type: string
          readOnly: true
        status_display:
          type: string
          readOnly: true
        payment_status_display:
          type: string
          readOnly: true
        lesson_type_display:
          type: string
          readOnly: true
        is_today:
          type: string
          readOnly: true
        is_upcoming:
          type: string
          readOnly: true
        date:
          type: string
          format: date
        start_time:
          type: string
          format: time
        end_time:
          type: string
          format: time
        lesson_type:
          $ref: '#/components/schemas/LessonTypeEnum'
        status:
          $ref: '#/components/schemas/StatusEnum'
        payment_status:
          $ref: '#/components/schemas/PaymentStatusEnum'
        lesson_fee:
