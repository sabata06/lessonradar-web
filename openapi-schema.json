        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedAssignmentRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedAssignmentRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedAssignmentRequest'
      security:
      - jwtAuth: []
      - Bearer:
          type: http
          scheme: bearer
          bearerFormat: JWT
