    post:
      operationId: auth_change_password_create
      description: |-
        Change password for authenticated user.

        POST /api/auth/change-password/
        {
            "current_password": "MevcutSifre123",
            "new_password": "YeniSifre123",
            "new_password_confirm": "YeniSifre123"
        }
